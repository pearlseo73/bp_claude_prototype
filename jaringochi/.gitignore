# ===========================================================
#  자린고치 (Jaringochi) - .gitignore
#  Maven + Servlet/JSP + STS(Eclipse) 프로젝트
# ===========================================================

# ---------- 빌드 산출물 ----------
target/
build/
out/
*.class
*.war
*.ear

# ---------- Maven ----------
# (Maven Wrapper를 쓰는 경우 아래 두 줄만 무시하고 mvnw 등은 커밋)
.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties
release.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
dependency-reduced-pom.xml

# ---------- Eclipse / STS ----------
# Maven 프로젝트로 다시 import 하면 자동 생성되므로 커밋하지 않음
.classpath
.project
.settings/
.factorypath
.apt_generated/
.springBeans
.sts4-cache/
bin/

# ---------- IntelliJ IDEA ----------
.idea/
*.iml
*.ipr
*.iws

# ---------- VS Code ----------
.vscode/

# ---------- NetBeans ----------
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# ---------- 로그 ----------
*.log
logs/

# ---------- OS 생성 파일 ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- 로컬 도구/비밀 설정 ----------
.claude/settings.local.json
.env
*.local.properties
